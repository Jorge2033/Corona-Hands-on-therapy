# Copia este archivo como .env.local y rellena los valores reales.
# .env.local NUNCA se sube a GitHub (está en .gitignore).

# Cuenta de Gmail que ENVÍA el correo (la misma clínica)
GMAIL_USER=coronahealthcare90@gmail.com

# Contraseña de aplicación de Gmail (NO tu contraseña normal).
# Se genera en: https://myaccount.google.com/apppasswords
# Requiere tener la verificación en 2 pasos activada en la cuenta de Gmail.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# A dónde llegan los correos de contacto (puede ser la misma cuenta)
CONTACT_TO_EMAIL=coronahealthcare90@gmail.com
