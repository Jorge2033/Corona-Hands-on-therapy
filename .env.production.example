# Copia este archivo como .env.production en el VPS y llena los valores reales.
# (Los 3 primeros son los mismos que tienes en tu .env.local de desarrollo)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_TO_EMAIL=

# Clave de cifrado de la base de datos (AES-256). Genera una con:
#   openssl rand -hex 32
# GUÁRDALA en un lugar seguro: sin ella los datos guardados no se pueden leer.
DATA_ENCRYPTION_KEY=
